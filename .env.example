PORT=3000

# Optional static fallback for auth when PocketBase is not configured
API_KEYS=key-abc123,key-xyz456

# PocketBase-backed auth (preferred)
PB_URL=https://your-pocketbase-host
PB_ADMIN_EMAIL=service-account@yourdomain.com
PB_ADMIN_PASSWORD=change-me

# Collection names from pb-schema.json
PB_COLLECTION_USERS=users
PB_COLLECTION_ACCOUNT=account
PB_COLLECTION_API_KEYS=api_keys

# Auth policy
PB_REQUIRE_VERIFIED_USER=true
PB_ALLOWED_API_KEY_STATUS=active
PB_ALLOWED_SUB_STATUSES=active,trialing
PB_FAIL_CLOSED=true

# Crawl4AI proxy
CRAWL4AI_BASE_URL=http://m4oco0sgog08o040g8o0os8o.69.62.114.245.sslip.io
CRAWL4AI_PATH=/crawl
CRAWL4AI_MAP_PATH=/crawl
CRAWL4AI_METADATA_PATH=/crawl
CRAWL4AI_GETMEDIA_PATH=/crawl
CRAWL4AI_TIMEOUT_MS=30000
