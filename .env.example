PORT=3000

# Optional static fallback for auth when PocketBase is not configured
API_KEYS=key-abc123,key-xyz456

# PocketBase-backed auth (preferred)
PB_URL=https://your-pocketbase-host
PB_ADMIN_EMAIL=service-account@yourdomain.com
PB_ADMIN_PASSWORD=change-me

# Collection names from pb-schema.json
PB_COLLECTION_USERS=users
PB_COLLECTION_ACCOUNT=account
PB_COLLECTION_API_KEYS=api_keys
PB_COLLECTION_PLANS=plans
PB_COLLECTION_USAGE_LOGS=usage_logs

# Auth policy
PB_REQUIRE_VERIFIED_USER=true
PB_ALLOWED_API_KEY_STATUS=active
PB_ALLOWED_SUB_STATUSES=active,trialing
PB_FAIL_CLOSED=true
PB_ENFORCE_ENDPOINT_ALLOWLIST=true
PB_ENFORCE_MONTHLY_CREDITS=true
PB_ENFORCE_KEY_MONTHLY_CREDITS=false
PB_CREDIT_CHECK_EXEMPT_ENDPOINTS=/v2/health,/v2/status,/v2/usage

# Usage log field mapping (align these with your PocketBase schema)
PB_USAGE_LOG_ACCOUNT_FIELD=account_id
PB_USAGE_LOG_API_KEY_FIELD=api_key
PB_USAGE_LOG_CREDIT_FIELD=credit_used
PB_USAGE_LOG_CREATED_FIELD=created
PB_USAGE_LOG_RESPONSE_CODE_FIELD=response_code
PB_USAGE_LOG_ENDPOINT_FIELD=endpoint
PB_USAGE_LOG_METHOD_FIELD=method
PB_USAGE_LOG_TIMESTAMP_FIELD=timestamp
PB_USAGE_LOG_LATENCY_FIELD=latency_ms
PB_USAGE_LOG_USER_AGENT_FIELD=user_agent
PB_USAGE_LOG_IP_FIELD=ip_address

# Crawl4AI proxy
CRAWL4AI_BASE_URL=http://m4oco0sgog08o040g8o0os8o.69.62.114.245.sslip.io
CRAWL4AI_PATH=/crawl
CRAWL4AI_MAP_PATH=/crawl
CRAWL4AI_METADATA_PATH=/crawl
CRAWL4AI_GETMEDIA_PATH=/crawl
CRAWL4AI_GETMARKDOWN_PATH=/crawl
CRAWL4AI_GETHTML_PATH=/crawl
CRAWL4AI_GETTEXT_PATH=/crawl
CRAWL4AI_GETSEO_PATH=/crawl
CRAWL4AI_GETEMAILS_PATH=/crawl
CRAWL4AI_EXTRACT_PATH=/crawl
CRAWL4AI_SCREENSHOT_PATH=/crawl
CRAWL4AI_BULK_PATH=/crawl
CRAWL4AI_TIMEOUT_MS=30000
